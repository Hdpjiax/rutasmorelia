# Dependencies
**/node_modules/

# Next.js build output
**/.next/
**/out/

# Expo / Mobile outputs
**/.expo/
**/dist/

# Env files
**/.env
**/.env*.local

# Logs and system files
**/*.log
**/.DS_Store

# Test outputs
**/coverage/

# Python generated caches
__pycache__/
*.py[cod]
.venv*/

# Database local folders
**/postgres_data/

